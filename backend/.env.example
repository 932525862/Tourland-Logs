# ===== Server =====
NODE_ENV=production
PORT=4000
# Comma-separated list of allowed frontend origins (no trailing slash). Use * for any.
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.com

# ===== Database (Postgres) =====
# When using docker-compose, the host is "postgres". For external DB use full URL.
DATABASE_URL=postgresql://crm:crm@postgres:5432/agency_crm?schema=public

# ===== Redis (BullMQ + WebSocket) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT =====
# CHANGE THIS to a long random string in production!
JWT_SECRET=change_me_super_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ===== Bootstrap director (auto-created on first run) =====
DIRECTOR_NAME=Direktor
DIRECTOR_LOGIN=admin
DIRECTOR_PASSWORD=admin123

# ===== Telegram bot =====
# Get a token from @BotFather on Telegram. Leave empty to disable bot.
TELEGRAM_BOT_TOKEN=
# Send reminder this many minutes BEFORE the payment due time.
TELEGRAM_REMINDER_LEAD_MINUTES=60
